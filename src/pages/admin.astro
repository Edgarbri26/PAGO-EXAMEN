---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdminAuthIsland from '../components/AdminAuthIsland.jsx';
import AdminPageIsland from '../components/AdminPageIsland.jsx';
---
<BaseLayout
    title="Admin | Gestión de Pagos y Exámenes"
    description="Panel administrativo para gestionar exámenes y validar pagos registrados."
    bodyClass="bg-gray-900 text-white min-h-screen p-3 sm:p-6 md:p-8"
>

    <div class="max-w-3xl mx-auto bg-gray-800 p-4 sm:p-6 rounded-lg shadow-lg">
        <h1 class="text-xl sm:text-2xl font-bold mb-6 text-indigo-400">Panel de Administración</h1>

        <!-- Login Form -->
        <div id="login-section">
            <h2 class="text-xl mb-4">Iniciar Sesión</h2>
            <form id="login-form" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-400">Email</label>
                    <input type="email" id="email" class="w-full p-2 rounded bg-gray-700 border border-gray-600 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-white" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-400">Contraseña</label>
                    <input type="password" id="password" class="w-full p-2 rounded bg-gray-700 border border-gray-600 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-white" required>
                </div>
                <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded transition duration-200">
                    Entrar
                </button>
            </form>
        </div>

        <!-- Admin Panel (Hidden by default) -->
        <div id="admin-section" class="hidden">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 mb-6">
                <h2 class="text-lg sm:text-xl text-green-400">Bienvenido</h2>
                <button id="logout-btn" class="text-sm text-gray-400 hover:text-white underline">Cerrar Sesión</button>
            </div>

            <h3 class="text-lg font-semibold mb-3 border-b border-gray-700 pb-2 flex justify-between items-center">
                <span id="form-title">Agregar Nuevo Examen</span>
                <button onclick="resetForm()" id="cancel-edit-btn" class="hidden text-xs bg-gray-600 hover:bg-gray-500 text-white px-2 py-1 rounded">Cancelar Edición</button>
            </h3>
            <form id="add-exam-form" class="space-y-4">
                <input type="hidden" id="exam-id"> <!-- Hidden ID for updates -->
                <div>
                    <label class="block text-sm font-medium text-gray-400">Título</label>
                    <input type="text" id="exam-title" class="w-full p-2 rounded bg-gray-700 border border-gray-600 text-white" placeholder="Ej: Matemáticas Final" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-400">Descripción</label>
                    <textarea id="exam-desc" class="w-full p-2 rounded bg-gray-700 border border-gray-600 text-white" rows="2" placeholder="Detalles..."></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-400">Precio (Bs)</label>
                    <input type="number" id="exam-price" class="w-full p-2 rounded bg-gray-700 border border-gray-600 text-white" step="0.50" placeholder="0.00" required>
                </div>
                <button type="submit" id="submit-btn" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded transition duration-200 flex items-center justify-center gap-2">
                    <i data-lucide="plus-circle" class="w-4 h-4"></i> <span id="btn-text">Guardar Examen</span>
                </button>
            </form>

            <div class="mt-8 mb-8">
                <h3 class="text-lg font-semibold mb-3 border-b border-gray-700 pb-2 text-yellow-500">Pagos Pendientes</h3>
                <div id="pending-payments-list" class="space-y-3">
                    <!-- Loaded dynamically -->
                </div>
            </div>

            <div class="mt-8 mb-8">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-3 border-b border-gray-700 pb-2">
                    <h3 class="text-lg font-semibold text-cyan-400">Pagos por Examen</h3>
                    <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
                        <select id="payments-exam-filter" class="w-full sm:w-auto bg-gray-700 border border-gray-600 rounded px-3 py-2 text-sm text-white min-w-0 sm:min-w-48">
                            <option value="">Cargando exámenes...</option>
                        </select>
                        <button id="copy-exam-list-btn" class="w-full sm:w-auto bg-cyan-600 hover:bg-cyan-700 text-white px-3 py-2 rounded text-sm font-medium flex items-center justify-center gap-1">
                            <i data-lucide="clipboard-copy" class="w-4 h-4"></i>
                            Copiar lista
                        </button>
                    </div>
                </div>

                <div id="payments-by-exam-list" class="space-y-3">
                    <!-- Loaded dynamically -->
                </div>

                <div id="payment-edit-section" class="hidden mt-4 bg-gray-700 p-4 rounded border border-gray-600">
                    <h4 class="font-semibold text-white mb-3">Editar Pago</h4>
                    <div class="space-y-3">
                        <div>
                            <label class="block text-xs text-gray-300 mb-1">Nombres</label>
                            <input id="edit-payment-names" type="text" class="w-full p-2 rounded bg-gray-800 border border-gray-600 text-white" />
                        </div>
                        <div>
                            <label class="block text-xs text-gray-300 mb-1">Tipo de pago</label>
                            <select id="edit-payment-type" class="w-full p-2 rounded bg-gray-800 border border-gray-600 text-white"></select>
                        </div>
                        <div id="edit-payment-reference-wrap">
                            <label class="block text-xs text-gray-300 mb-1">Referencia</label>
                            <input id="edit-payment-reference" type="text" class="w-full p-2 rounded bg-gray-800 border border-gray-600 text-white" />
                        </div>
                        <div>
                            <label class="block text-xs text-gray-300 mb-1">Nota</label>
                            <textarea id="edit-payment-note" rows="2" class="w-full p-2 rounded bg-gray-800 border border-gray-600 text-white"></textarea>
                        </div>
                        <div>
                            <label class="block text-xs text-gray-300 mb-1">Estado</label>
                            <select id="edit-payment-status" class="w-full p-2 rounded bg-gray-800 border border-gray-600 text-white">
                                <option value="pending">Pendiente</option>
                                <option value="approved">Aprobado</option>
                                <option value="rejected">Rechazado</option>
                            </select>
                        </div>
                        <div class="flex flex-col sm:flex-row gap-2">
                            <button onclick="savePaymentEdit()" class="flex-1 bg-cyan-600 hover:bg-cyan-700 text-white py-2 px-3 rounded text-sm font-medium">Guardar cambios</button>
                            <button onclick="cancelPaymentEdit()" class="flex-1 bg-gray-600 hover:bg-gray-500 text-white py-2 px-3 rounded text-sm font-medium">Cancelar</button>
                        </div>
                        <button onclick="deleteCurrentPayment()" class="w-full bg-red-600 hover:bg-red-700 text-white py-2 px-3 rounded text-sm font-medium flex items-center justify-center gap-2">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                            Eliminar pago
                        </button>
                    </div>
                </div>
            </div>

            <div class="mt-8">
                <h3 class="text-lg font-semibold mb-3 border-b border-gray-700 pb-2">Exámenes Actuales</h3>
                <div id="exams-list" class="space-y-3 text-sm text-gray-300">
                    <!-- Loaded dynamically -->
                </div>
            </div>
        </div>
    </div>

    <AdminAuthIsland client:load />
    <AdminPageIsland client:load />
</BaseLayout>
